# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# The public-facing base URL of this API server (no trailing slash).
# Required when deploying behind a reverse proxy, on Vercel, or any host where
# the automatic URL detection might be wrong.
# Local:   http://localhost:3001
# Vercel:  https://your-api.vercel.app
APP_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Authentication ───────────────────────────────────────────────────────────
# Long random string used to sign JWT tokens.
# Generate with: openssl rand -hex 64
SESSION_SECRET=replace_with_a_very_long_random_string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# Leave blank to allow all origins (not recommended in production).
# Example: https://plutonium-smp.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# ─── Discord OAuth ────────────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# Add this redirect URI in the OAuth2 settings:
#   <APP_URL>/api/auth/discord/callback
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ─── Email ────────────────────────────────────────────────────────────────────
# Option A – Resend (recommended for production)
RESEND_API_KEY=re_your_resend_api_key

# Option B – SMTP (fallback when RESEND_API_KEY is not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# The "From" address used for all outgoing emails
SMTP_FROM=noreply@yourdomain.com

# ─── Logging ──────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
