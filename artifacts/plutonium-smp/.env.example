# ─── API Connection ───────────────────────────────────────────────────────────
# Full URL of your API server (no trailing slash).
# Local development: leave blank — Vite proxies /api → localhost:3001 for you.
# Production / Vercel: set to your deployed API URL.
VITE_API_URL=https://your-api.vercel.app

# ─── Base Path ────────────────────────────────────────────────────────────────
# Only change this if your frontend is served from a sub-path (e.g. /app).
# Leave as "/" for root deployments.
BASE_PATH=/
